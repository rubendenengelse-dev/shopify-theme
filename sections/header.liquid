<script>
  document.addEventListener('DOMContentLoaded', () => {
    const desktopQuery = window.matchMedia('(min-width: 990px)');
    if (!desktopQuery.matches) return;

    const menuItems = document.querySelectorAll('header-menu details');
    const closeTimers = new WeakMap();

    menuItems.forEach((item) => {
      const summary = item.querySelector('summary');
      const content = item.querySelector('.mega-menu__content');
      const clearCloseTimer = () => {
        const timer = closeTimers.get(item);
        if (timer) {
          window.clearTimeout(timer);
          closeTimers.delete(item);
        }
      };

      const openMenu = () => {
        clearCloseTimer();

        menuItems.forEach((other) => {
          if (other !== item) {
            const otherTimer = closeTimers.get(other);
            if (otherTimer) {
              window.clearTimeout(otherTimer);
              closeTimers.delete(other);
            }
            other.removeAttribute('open');
          }
        });

        item.setAttribute('open', '');
      };

      const closeMenu = () => {
        clearCloseTimer();
        const timer = window.setTimeout(() => {
          item.removeAttribute('open');
        }, 220);
        closeTimers.set(item, timer);
      };

      item.addEventListener('mouseenter', openMenu);
      item.addEventListener('mouseleave', closeMenu);

      if (summary) {
        summary.addEventListener('mouseenter', openMenu);
        summary.addEventListener('click', (event) => {
          if (desktopQuery.matches) {
            event.preventDefault();
          }
        });
      }

      if (content) {
        content.addEventListener('mouseenter', clearCloseTimer);
        content.addEventListener('mouseleave', closeMenu);
      }
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const desktopQuery = window.matchMedia('(min-width: 990px)');
    if (!desktopQuery.matches) return;

    const menuColumns = document.querySelectorAll('.mega-menu__list > li');

    menuColumns.forEach((column) => {
      column.addEventListener('mousemove', (event) => {
        const rect = column.getBoundingClientRect();
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        column.style.setProperty('--divider-y', `${y}%`);
      });

      column.addEventListener('mouseleave', () => {
        column.style.setProperty('--divider-y', '50%');
      });
    });
  });
</script>

