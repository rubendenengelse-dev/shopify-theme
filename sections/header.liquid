{% comment %}theme-check-disable UndefinedObject{% endcomment %}
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{% if settings.predictive_search_enabled %}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{% endif %}

{% if section.settings.menu_type_desktop == 'mega' %}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{% endif %}

{% if section.blocks.size >= 2 %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
{% endif %}

<style>
  header-drawer {
    justify-self: start;
    margin-left: 0;
  }

  {% if section.settings.sticky_header_type == 'reduce-logo-size' %}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {% endif %}

  {% if section.settings.menu_type_desktop != 'drawer' %}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {% endif %}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-top: 1rem;
    padding-bottom: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
  }

  .mega_menu_img {
    padding-bottom: 20px;
  }

  .mega_menu_img img {
    max-width: 70%;
    height: auto;
    display: block;
    margin-right: auto;
    margin-left: auto;
    object-fit: cover;
    transition: transform 0.6s ease, opacity 0.3s ease;
    border-radius: 1.4rem;
  }

  .mega_menu_img:hover img {
    transform: scale(1.04);
  }

  .mega_menu_img .mega-menu__link {
    padding-top: 0;
  }

  .mega_menu_img div {
    text-align: center;
    overflow: hidden;
    padding: 0;
    margin: 0;
  }

  .mega_menu_img .title {
    padding-top: 1rem;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .mega-menu__list {
    gap: 0;
    display: flex;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
    row-gap: 20px;
  }

  .list-unstyled .mega_menu_img {
    width: 100%;
    max-width: 100%;
    padding-top: 10px;
  }

  @media (min-width: 768px) {
    .mega-menu__list > li {
      list-style: none;
      display: block;
      flex: 0 0 20%;
      max-width: 25%;
      padding-right: 15px;
    }
  }

  .mega_menu_img.slide {
    flex: 0 0 260px;
    max-width: 100%;
    margin: 0;
    padding-right: 15px;
    scroll-snap-align: start;
  }

  .mega_menu_img.slide:first-child {
    padding-left: 0;
  }

  .js .menu-drawer__submenu {
    z-index: 2;
  }

  .swiper {
    margin-top: 15px;
    padding: 0 3rem;
  }

  .swiper .mega-menu__link .title {
    text-align: start;
  }

 @media screen and (min-width: 990px) {
  .header-wrapper {
    background: rgba(var(--color-background), 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.06);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
  }

  .header {
    min-height: 8.6rem;
    align-items: center;
    padding-left: 3.2rem;
    padding-right: 3.2rem;
    column-gap: 2.4rem;
  }

.header--middle-left {
  grid-template-areas: 'navigation heading icons';
  grid-template-columns: 1fr auto 1fr;
  column-gap: 2.4rem;
  align-items: center;
  position: relative;
}

.header__heading,
.header__inline-menu,
.header__icons {
  position: relative;
}

.header__heading {
  grid-area: heading;
  justify-self: center;
  z-index: 3;
  margin: 0 !important;
  position: relative;
  left: auto;
  top: auto;
  transform: none;
}

.header--middle-left .header__heading-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
}

.header__inline-menu {
  grid-area: navigation;
  justify-self: start;
  z-index: 2;
}

.header__icons {
  grid-area: icons;
  justify-self: end;
  z-index: 4;
}

.header__heading-logo-wrapper {
  display: flex;
  align-items: center;
  width: 110px !important;
  max-width: 110px !important;
}

.header__heading-logo {
  display: block;
  width: 100% !important;
  max-width: 100% !important;
  height: auto !important;
  max-height: none !important;
  object-fit: contain;
}

.header--middle-left .header__inline-menu {
  grid-area: navigation;
  justify-self: start;
  width: max-content;
  margin-left: -68rem;
}

.header--middle-left .header__inline-menu .list-menu--inline {
  align-items: center;
  gap: 2.2rem;
  flex-wrap: nowrap;
  justify-content: flex-start;
}

.header--middle-left .header__icons {
  grid-area: icons;
  justify-self: end;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.2rem;
  padding-right: 0;
  margin-right: -70rem;
}

  .header__menu-item {
    padding: 1.1rem 0;
    font-size: 1.38rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none !important;
    box-shadow: none !important;
  }

  .header__menu-item .icon-caret,
  .header__menu-item svg {
    display: none !important;
  }

  .header__menu-item > span {
    position: relative;
    text-decoration: none !important;
    box-shadow: none !important;
  }

  .header__menu-item > span::before,
  .header__active-menu-item::before {
    content: none !important;
  }

  .header__menu-item > span::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.45rem;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.24s ease;
    opacity: 0.7;
  }

  .header__menu-item:hover > span::after,
  .header__menu-item:focus-visible > span::after {
    transform: scaleX(1);
  }

  .header__active-menu-item {
    position: relative;
    text-decoration: none !important;
    box-shadow: none !important;
    border-bottom: 0 !important;
  }

  .header__active-menu-item::after {
    content: none !important;
  }

  .header__menu-item,
  .header__menu-item:hover,
  .header__menu-item:focus-visible,
  .header__active-menu-item {
    text-decoration: none !important;
    box-shadow: none !important;
  }

  header-menu {
    position: static;
  }

  header-menu details {
    position: static;
  }

  header-menu details > summary {
    cursor: pointer;
  }

  header-menu details[open] > .mega-menu__content {
    animation: fadeInMegaMenu 0.24s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes fadeInMegaMenu {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  header-menu details[open] > summary {
    opacity: 1;
    background: transparent;
  }

.mega-menu {
  position: static !important;
}

.mega-menu__content,
.mega-menu__content.global-settings-popup {
  left: calc(50% - 25rem);
  right: auto;
  transform: translateX(-50%);
  width: 100vw;
  max-width: 100vw;
  margin-left: 0;
  margin-right: 0;
  margin-top: 0;
  padding: 3.6rem 2rem 4rem;
  border: 0;
  box-shadow: 0 30px 70px rgba(0, 0, 0, 0.10);
  overflow: hidden;
  background: linear-gradient(
    180deg,
    rgba(var(--color-background), 0.98) 0%,
    rgba(var(--color-background), 1) 100%
  );
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

  .mega-menu__content::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(var(--color-foreground), 0.02) 0%,
      transparent 18%,
      transparent 82%,
      rgba(var(--color-foreground), 0.02) 100%
    );
  }

  .mega-menu__panel {
    position: relative;
    width: 100%;
    max-width: none;
    margin: 0;
    min-height: 22rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 40rem;
    align-items: start;
    column-gap: 2rem;
  }

  .mega-menu__panel::before {
    content: none;
  }

  .mega-menu__main {
    width: 100%;
    min-width: 0;
    display: flex;
    justify-content: flex-start;
  }

  .mega-menu__promo {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
    width: 40rem;
    max-width: 40rem;
    justify-self: end;
  }

  .mega-menu__promo-item {
    list-style: none;
  }

  .mega-menu__promo-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .mega-menu__promo-card-image {
    border-radius: 1.6rem;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.03);
  }

  .mega-menu__promo-card-image img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega-menu__promo-card:hover .mega-menu__promo-card-image img {
    transform: scale(1.045);
  }

  .mega-menu__promo-card-title {
    display: inline-block;
    margin-top: 1rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #000 !important;
  }

  .mega-menu__list {
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    align-items: start;
    gap: 4rem;
    width: max-content;
    max-width: none;
    margin: 0 0 0 3rem;
    padding: 0;
  }

  .mega-menu__list > li {
    position: relative;
    flex: 0 0 auto;
    min-width: 16rem;
    padding-right: 0;
    --divider-y: 50%;
    transition: transform 0.25s ease;
  }

  .mega-menu__list > li:hover {
    transform: translateY(-1px);
  }

  .mega-menu__list > li::before {
    content: '';
    position: absolute;
    top: 0.2rem;
    left: -2rem;
    width: 1px;
    height: calc(100% - 0.4rem);
    opacity: 0.9;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(var(--color-foreground), 0.05) 20%,
      rgba(var(--color-foreground), 0.12) 42%,
      rgba(var(--color-foreground), 0.22) 50%,
      rgba(var(--color-foreground), 0.12) 58%,
      rgba(var(--color-foreground), 0.05) 80%,
      transparent 100%
    );
    background-size: 100% 220%;
    background-position: center var(--divider-y);
    transition: background-position 0.14s ease, opacity 0.2s ease;
  }

  .mega-menu__list > li:hover::before {
    opacity: 1;
  }

  .mega-menu__list > li:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 0.2rem;
    right: -2rem;
    width: 1px;
    height: calc(100% - 0.4rem);
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(var(--color-foreground), 0.10),
      transparent
    );
  }

  .mega-menu__link--level-2 {
    display: inline-block;
    position: relative;
    margin-bottom: 1.3rem;
    font-size: 1.34rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #000 !important;
    opacity: 1 !important;
    text-decoration: none !important;
    box-shadow: none !important;
  }

  .mega-menu__link {
    display: inline-block;
    position: relative;
    padding: 0.48rem 0;
    font-size: 1.46rem;
    line-height: 1.55;
    font-weight: 400;
    letter-spacing: 0.005em;
    color: rgba(var(--color-foreground), 0.86);
    opacity: 1;
    text-decoration: none !important;
    box-shadow: none !important;
  }

  .mega-menu__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.08rem;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.28s ease;
    opacity: 0.32;
  }

  .mega-menu__link:hover::after,
  .mega-menu__link:focus-visible::after,
  .mega-menu__link--active::after {
    transform: scaleX(1);
  }

  .mega-menu__link,
  .mega-menu__link--level-2 {
    transition: color 0.22s ease, opacity 0.22s ease;
  }

  .mega-menu__link:hover,
  .mega-menu__link--level-2:hover,
  .mega-menu__link--active,
  .mega-menu__link--level-2.mega-menu__link--active {
    opacity: 1;
  }

  .header--middle-left .header__icons {
    grid-area: icons;
    justify-self: end;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.2rem;
    padding-right: 0;
    margin-right: -70rem;
  }

  .header__icon,
  .header__search,
  .header__icon--cart,
  .header__icon--account {
    width: 4.4rem;
    height: 4.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .header__icon--cart {
    position: relative;
    margin-right: 0 !important;
  }

  .header__icon:hover,
  .header__icon:focus-visible,
  .header__search:hover,
  .header__search:focus-visible,
  .header__icon--cart:hover,
  .header__icon--cart:focus-visible,
  .header__icon--account:hover,
  .header__icon--account:focus-visible {
    background-color: rgba(var(--color-foreground), 0.04);
    box-shadow: inset 0 0 0 1px rgba(var(--color-foreground), 0.06);
    transform: translateY(-1px);
  }

  .header__icon .svg-wrapper,
  .header__search .svg-wrapper,
  .header__icon--account .svg-wrapper,
  .header__icon .icon,
  .header__search .icon,
  .header__icon--account .icon,
  .header__icon svg,
  .header__search svg,
  .header__icon--account svg {
    width: 1.9rem !important;
    height: 1.9rem !important;
  }

  .header__icon--cart .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem !important;
    height: 1.9rem !important;
    line-height: 0;
  }

  .header__icon--cart .icon-cart,
  .header__icon--cart .icon-cart-empty,
  .header__icon--cart svg {
    width: 1.9rem !important;
    height: 1.9rem !important;
    min-width: 1.9rem !important;
    min-height: 1.9rem !important;
    transform: none !important;
  }

  .cart-count-bubble {
    bottom: 0.6rem;
    left: 2.3rem;
  }

.header__search {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rem;
  background: transparent !important;
  outline: none !important;
  box-shadow: none !important;
  border: 0 !important;
  transform: none !important;
}

.header__search:focus,
.header__search:focus-visible,
.header__search:focus-within,
.header__search:hover,
.header__search:active,
.header__search *:focus,
.header__search *:focus-visible {
  background: transparent !important;
  outline: none !important;
  box-shadow: none !important;
  border: 0 !important;
  transform: none !important;
}

.header__search .desktop-search-toggle {
  width: auto;
  min-width: 22rem;
  height: 4.2rem;
  min-height: 4.2rem;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  gap: 1.4rem;
  padding: 0 2.2rem;
  margin: 0;
  border: 0 !important;
  outline: 0 !important;
  border-radius: 999px;
  background: #f3f1ee;
  box-shadow: none !important;
  text-decoration: none !important;
  appearance: none;
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  border-color: transparent !important;
  border-style: solid !important;
  border-width: 0 !important;
  transition: background-color 0.2s ease;
}

.header__search .mobile-search-toggle {
  display: none;
}

.standalone-mobile-search-toggle {
  display: none;
}

.header__search .desktop-search-toggle,
.header__search .desktop-search-toggle::before,
.header__search .desktop-search-toggle::after {
  box-shadow: none !important;
  outline: none !important;
  border: 0 !important;
}

.header__search .desktop-search-toggle.header__icon,
.header__search .desktop-search-toggle.header__icon:hover,
.header__search .desktop-search-toggle.header__icon:focus,
.header__search .desktop-search-toggle.header__icon:focus-visible,
.header__search .desktop-search-toggle.header__icon:active,
.header__search .desktop-search-toggle.header__icon:focus-within {
  box-shadow: none !important;
  outline: none !important;
  border: 0 !important;
  border-color: transparent !important;
  transform: none !important;
}

.header__search .desktop-search-toggle.header__icon:hover,
.header__search .desktop-search-toggle.header__icon:focus,
.header__search .desktop-search-toggle.header__icon:focus-visible,
.header__search .desktop-search-toggle.header__icon:active,
.header__search .desktop-search-toggle.header__icon:focus-within {
  background: #ece8e3 !important;
}

.header__search .desktop-search-toggle.header__icon::before,
.header__search .desktop-search-toggle.header__icon::after,
.header__search .desktop-search-toggle.header__icon:hover::before,
.header__search .desktop-search-toggle.header__icon:hover::after,
.header__search .desktop-search-toggle.header__icon:focus::before,
.header__search .desktop-search-toggle.header__icon:focus::after,
.header__search .desktop-search-toggle.header__icon:focus-visible::before,
.header__search .desktop-search-toggle.header__icon:focus-visible::after,
.header__search .desktop-search-toggle.header__icon:active::before,
.header__search .desktop-search-toggle.header__icon:active::after {
  box-shadow: none !important;
  outline: none !important;
  border: 0 !important;
}

{% if section.settings.search_placeholder_text != blank %}
  .header__search .desktop-search-toggle::after {
    content: {{ section.settings.search_placeholder_text | json }};
    font-size: 1.14rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.42);
    white-space: nowrap;
  }
{% endif %}

.header__search .desktop-search-toggle:hover,
.header__search .desktop-search-toggle:focus-visible {
  background: #ece8e3;
  box-shadow: none !important;
  outline: none !important;
  border: 0 !important;
  transform: none !important;
}

.header__search .desktop-search-toggle:focus,
.header__search .desktop-search-toggle:active,
.header__search .desktop-search-toggle:focus-within,
.header__search .desktop-search-toggle:visited,
.header__search .desktop-search-toggle:hover {
  background: #ece8e3;
  outline: none !important;
  border: 0 !important;
  box-shadow: none !important;
  border-color: transparent !important;
  transform: none !important;
}

.header__search svg,
.header__search .icon,
.header__search .svg-wrapper {
  width: 2rem !important;
  height: 2rem !important;
  flex: 0 0 2rem;
}

body.desktop-search-open .header__search .desktop-search-toggle {
  opacity: 0;
  pointer-events: none;
}

.desktop-search-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  min-height: 42rem;
  background: #ffffff;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  z-index: 10000;
  margin: 0;
}

.desktop-search-panel::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 8.2rem;
  height: 1px;
  background: rgba(0, 0, 0, 0.08);
}

.desktop-search-panel[hidden] {
  display: none !important;
}

body.desktop-search-open .desktop-search-panel {
  display: block !important;
}

.desktop-search-panel__surface {
  position: relative;
  min-height: 40rem;
  width: min(160rem, calc(100vw - 6rem));
  max-width: min(160rem, calc(100vw - 6rem));
  margin: 0 auto;
  padding: 1.6rem 4rem 4.8rem;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: #ffffff;
}

.desktop-search-panel__logo {
  position: fixed;
  top: 1.4rem;
  left: 1.2rem;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  max-width: 8rem;
  text-decoration: none;
}

.desktop-search-panel__logo-image {
  display: block;
  width: auto;
  max-width: 5.6rem;
  height: auto;
  object-fit: contain;
}

.desktop-search-panel__logo-text {
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
